command -v dotfiles_is_macos >/dev/null 2>&1 || source "$HOME/.dotfiles/scripts/host_common"

# ASDF

for asdf_init in \
  /usr/local/opt/asdf/libexec/asdf.sh \
  /opt/homebrew/opt/asdf/libexec/asdf.sh \
  "$HOME/.asdf/asdf.sh"
do
  [[ -e "$asdf_init" ]] || continue
  . "$asdf_init"
  break
done

# Dirish

alias p-pull='java -jar ~/p/jd/dirish/target/dirish.jar -c ~/p/meta/p.dirish pull'
alias p-status='java -jar ~/p/jd/dirish/target/dirish.jar -c ~/p/meta/p.dirish status'
alias p-sync='java -jar ~/p/jd/dirish/target/dirish.jar -c ~/p/meta/p.dirish sync'

# Nix

if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then . "$HOME/.nix-profile/etc/profile.d/nix.sh"; fi

# NVM

unset NPM_CONFIG_PREFIX 2>/dev/null || true
export NVM_DIR="${HOME}/.config/nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  . "$NVM_DIR/nvm.sh"
elif dotfiles_is_macos && command -v brew >/dev/null; then
  . "$(brew --prefix nvm)/nvm.sh" || true
fi

dotfiles_prepend_to_path_if_dir "$DOTFILES_NPM_PREFIX/bin"

# SDKMan

if [[ -f "$SDKMAN_DIR/etc/config" ]]; then
  if grep -q '^sdkman_native_enable=' "$SDKMAN_DIR/etc/config"; then
    local_sdkman_config_tmp="$SDKMAN_DIR/etc/config.tmp.$$"
    sed 's/^sdkman_native_enable=.*/sdkman_native_enable=false/' "$SDKMAN_DIR/etc/config" > "$local_sdkman_config_tmp" && mv "$local_sdkman_config_tmp" "$SDKMAN_DIR/etc/config"
  else
    printf 'sdkman_native_enable=false\n' >> "$SDKMAN_DIR/etc/config"
  fi
fi
if [[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]]; then
  local_had_nounset=0
  [[ $- == *u* ]] && local_had_nounset=1
  set +u
  source "$SDKMAN_DIR/bin/sdkman-init.sh"
  (( local_had_nounset )) && set -u

  if typeset -f sdk >/dev/null 2>&1 && ! typeset -f __dotfiles_sdkman_sdk >/dev/null 2>&1; then
    if [[ -n "${ZSH_VERSION:-}" ]]; then
      functions -c sdk __dotfiles_sdkman_sdk
    else
      eval "$(declare -f sdk | sed '1s/^sdk[[:space:]]/__dotfiles_sdkman_sdk /')"
    fi

    sdk() {
      local had_nounset=0
      [[ $- == *u* ]] && had_nounset=1
      set +u
      __dotfiles_sdkman_sdk "$@"
      local rc=$?
      (( had_nounset )) && set -u
      return $rc
    }
  fi
fi

# Git

function acp { # Add, commit, push.
  git add . && git commit -m "$*" && git push
}

alias ga.='git add .'
alias gadd='git add'
alias gam-n='git commit --amend --no-edit'
alias gamend='git commit --amend'
alias gcheck='git checkout'
alias gcomm='git commit'
alias gfetch='git fetch'
alias glog='git log'
alias gls='git ls'
alias gst='git st'
alias gstat='git status'
alias gpull='git pull'
alias gpush='git push'
alias gpu-f='git push --force-with-lease'
alias greb='git rebase'

# Java

alias jdefault="sdk install java ${DOTFILES_DEFAULT_JAVA_VERSION} && sdk default java ${DOTFILES_DEFAULT_JAVA_VERSION}"
alias juse="sdk install java ${DOTFILES_DEFAULT_JAVA_VERSION} && sdk use java ${DOTFILES_DEFAULT_JAVA_VERSION}"
alias jcurrent="sdk current java"
alias jenv="sdk env"
alias jenv-init="sdk env init"

jproject() {
  local version="${1:-$DOTFILES_DEFAULT_JAVA_VERSION}"
  printf 'java=%s\n' "$version" > .sdkmanrc
  sdk install java "$version"
  sdk env
}

# Maintenance

"$HOME/.dotfiles/util/check-dotfiles.sh" # Report unknown or superfluous dotfiles in the home directory.
"$HOME/.dotfiles/util/maintain-zsh-plugins.sh" # Make sure all required plugins are installed.
"${HOME}/.dotfiles/util/auto-update.sh" # Warn if dotfiles are out of date.
[[ -f "${HOME}/.dotfiles-private/util/auto-update.sh" ]] && "${HOME}/.dotfiles-private/util/auto-update.sh"

# Navigation

alias ..='cd ..'
alias ...='cd ../..'
alias cd..='cd ..'

# Private

[[ -f "$HOME/.dotfiles-private/scripts/post_rc" ]] && source "$HOME/.dotfiles-private/scripts/post_rc"

# Terminal size

# Fix for JetBrains terminal sometimes not setting the terminal dimensions when restoring a project:
if [[ "${TERMINAL_EMULATOR:-}" = 'JetBrains-JediTerm' && `stty size` = '0 0' ]]; then
  stty cols 248
fi

# Travis

[[ -f "$HOME/.travis/travis.sh" ]] && source "$HOME/.travis/travis.sh"

# Typing

if command -v subl >/dev/null; then
  alias e=subl
elif command -v nvim >/dev/null; then
  alias e=nvim
else
  alias e=vim
fi
alias la='ls -lAh'
alias ll='ls -hl'
if dotfiles_is_macos; then
  alias ls="ls -FG"
else
  alias ls="ls --color=auto -F"
fi
alias new-uuid='uuidgen | tr "[:upper:]" "[:lower:]"'
