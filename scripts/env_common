command -v dotfiles_is_macos >/dev/null 2>&1 || source "$HOME/.dotfiles/scripts/host_common"

# Editor

if dotfiles_is_macos && command -v subl >/dev/null; then
  EDITOR="subl -n -w"
elif command -v nvim >/dev/null; then
  EDITOR="nvim"
else
  EDITOR="vim"
fi
export EDITOR

# History

HISTCONTROL=ignoreboth:ignorespace
HISTFILE="$HOME/.history"
HISTSIZE=1000
SAVEHIST=1000

# pkg-config

if dotfiles_is_macos; then
  export PKG_CONFIG_PATH="/usr/local/share/pkgconfig"
fi

# Rust

export CARGO_HOME="$HOME/.config/cargo"
export RUSTUP_HOME="$HOME/.config/rustup"

# Node / npm

export NPM_CONFIG_PREFIX="$HOME/.local/share/npm"

# SBT

SBT_OPTS='-Xmx8G -XX:ReservedCodeCacheSize=2G -XX:MaxMetaspaceSize=1G -Xss4m'

# SDKMAN

export SDKMAN_DIR="$HOME/.sdkman"
export DOTFILES_DEFAULT_JAVA_VERSION="${DOTFILES_DEFAULT_JAVA_VERSION:-26-tem}"
export DOTFILES_DEFAULT_NPM_VERSION="${DOTFILES_DEFAULT_NPM_VERSION:-11.13.0}"

# Finally: paths

dotfiles_add_to_path_if_dir "$CARGO_HOME/bin"
dotfiles_add_to_path_if_dir "$NPM_CONFIG_PREFIX/bin"
dotfiles_add_to_path_if_dir "$HOME/.nimble/bin"
dotfiles_add_to_path_if_dir "$HOME/bin"
dotfiles_add_to_path_if_dir "$HOME/bin/shared"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/confluent/bin"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/maven/bin"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/prince"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/sbt/bin"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/scala/bin"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/stack"
dotfiles_add_to_path_if_dir "$HOME/bin/shared/zig"

if dotfiles_is_macos; then
  INFOPATH=$INFOPATH:/opt/local/share/info
  MANPATH=$MANPATH:/opt/local/share/man

  dotfiles_add_to_path_if_dir "$HOME/Library/Application Support/Coursier/bin"
  dotfiles_add_to_path_if_dir "$HOME/Library/Python/2.7/bin"
  dotfiles_add_to_path_if_dir "/Library/Frameworks/Python.framework/Versions/Current/bin"
  dotfiles_add_to_path_if_dir "/opt/local/bin"
  dotfiles_add_to_path_if_dir "/opt/local/sbin"
  dotfiles_add_to_path_if_dir "/opt/homebrew/bin"
fi

export PATH
